# [Setup #1 / Backend #3] Variaveis de ambiente do backend (sem valores reais; nunca commitar o .env).
# Ver issues: https://github.com/vitinh0z/portfolio/issues/1 e /issues/3

# GitHub OAuth App (criar em GitHub > Settings > Developer settings > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Banco (ja usados pelo docker-compose / application.properties)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio
DB_USER=postgres
DB_PASSWORD=postgres
